rules_version = '2';

// -------------------------------------------------------------------
// DEVELOPMENT RULES — these allow anyone to read and write everything.
// That is fine while building and testing with sample data, but it MUST
// be replaced with sign-in-based rules before any real data goes in.
// Locking this down with Firebase Auth is the next step after this
// foundation (see README.md > What's next).
// -------------------------------------------------------------------

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
