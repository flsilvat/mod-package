rules_version = '2';

// -------------------------------------------------------------------
// Access rules.
//   - You must be signed in AND have a userRoles document to read.
//   - Only role 'admin' can create / edit / delete.
// Manage people by adding documents to the `userRoles` collection,
// id = the person's email (lowercase), with a field `role` of
// 'admin' or 'viewer'. The first admin doc is created by hand in the
// Firebase console (see README.md).
// -------------------------------------------------------------------

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // A signed-in person counts as a user only if they have a role doc.
    function isUser() {
      return signedIn() &&
        exists(/databases/$(database)/documents/userRoles/$(request.auth.token.email));
    }

    function isAdmin() {
      return isUser() &&
        get(/databases/$(database)/documents/userRoles/$(request.auth.token.email)).data.role == 'admin';
    }

    // Role docs: any signed-in person may read (the app reads its own role
    // to find out what it can do); only admins may hand out or change roles.
    match /userRoles/{email} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // All app data: authorised users read, admins write.
    match /{document=**} {
      allow read: if isUser();
      allow write: if isAdmin();
    }
  }
}
